# Deed & Plat Helper — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.
# The launch .bat will automatically load these on startup.
# NEVER commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# JWT secret key — change this to a long random string in production
DEED_SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── Stripe (optional — only needed for paid subscriptions) ───────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get this by running: stripe listen --forward-to localhost:5000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Your public app URL (used for Stripe redirect URLs)
# For local dev: http://localhost:5000
# For production: https://yourapp.com
DEED_APP_URL=http://localhost:5000

# ── Stripe Price IDs (pre-filled with your test products) ────────────────────
STRIPE_PRO_PRICE_ID=price_1TIZrNR0DNgIZfm7dVBvQuJi
STRIPE_TEAM_PRICE_ID=price_1TIZtZR0DNgIZfm77NN3RBxA
